___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const injectScript = require('injectScript');
const setInWindow = require('setInWindow');
const makeNumber = require('makeNumber');

function toList(str) {
  const out = [];
  if (!str) {
    return out;
  }
  const parts = str.split(',');
  for (let i = 0; i < parts.length; i++) {
    const t = parts[i].trim();
    if (t.length > 0) {
      out.push(t);
    }
  }
  return out;
}

const cfg = {
  eventName: data.eventName || 'form_interaction',
  formInteractionType: data.formInteractionType || 'lead_form',
  consentCookie: data.consentCookie || 'OptanonConsent',
  requiredConsentGroups: toList(data.requiredConsentGroups),
  defaultAudience: data.defaultAudience || 'unknown',
  audienceKey: data.audienceKey || '',
  extraSelectors: toList(data.extraSelectors),
  validationDelay: data.validationDelay ? makeNumber(data.validationDelay) : 600,
  debugMode: data.debugMode === true
};

// Hand configuration to the hosted runtime, then load it (cache-keyed by URL).
setInWindow('faConfig', cfg, true);

const url = data.scriptUrl;
injectScript(url, data.gtmOnSuccess, data.gtmOnFailure, url);


